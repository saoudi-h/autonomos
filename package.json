        "@tala-tools/prettier": "0.0.3",
        "@tala-tools/tsconfig": "0.0.1",
        "@tala-tools/tsdown": "0.1.3",
        "@types/eslint": "^9.6.1",
        "@types/node": "^25.0.3",
        "eslint": "^10.4.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.2.7",
        "prettier": "^3.7.4",
        "prettier-plugin-organize-imports": "^4.3.0",
        "publint": "^0.3.21",
        "rimraf": "^6.1.2",
        "tsdown": "^0.22.1",
        "turbo": "^2.7.2",
        "typescript": "^5.9.3",
        "unplugin-unused": "^0.5.7",
        "vite-tsconfig-paths": "^6.0.3"
